# 必填：Session 加密密钥（生产环境请用随机字符串）
SECRET_KEY=change-me-to-a-random-string

# 必填：DeepSeek API Key（不启用 LLM 可留空）
DEEPSEEK_API_KEY=sk-your-deepseek-key

# 可选：LLM 功能开关（默认 false）
LLM_ENABLED=true

# 可选：数据库路径（默认 /app/data/gameplan.db）
# DATABASE_URL=sqlite:////app/data/gameplan.db

# 可选：服务端口（默认 8000）
# BACKEND_PORT=8000
