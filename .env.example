# GamePlan 环境变量配置
# 复制此文件为 .env 并填入实际值

# 会话密钥（生产环境务必修改为随机字符串）
SECRET_KEY=change-me-in-production

# ---- DeepSeek API Key（二选一）----
# 方式一：明文（不推荐，仅开发环境使用）
# DEEPSEEK_API_KEY=sk-your-key-here

# 方式二：加密存储（推荐）
# 使用 backend/encrypt_key.py 生成：
#   1. python backend/encrypt_key.py --generate          → 得到 MASTER_KEY
#   2. MASTER_KEY=<主密钥> python backend/encrypt_key.py --encrypt "sk-xxx"  → 得到密文
#   3. 将主密钥和密文填入下方：
MASTER_KEY=
DEEPSEEK_API_KEY_ENC=

# ---- 可选配置 ----
LLM_ENABLED=true
DEEPSEEK_MODEL=deepseek-chat
SESSION_DAYS=7
